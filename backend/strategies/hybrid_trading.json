{
    "name": "Hybrid_Trading",
    "enabled": true,
    "description": "Minervini VCP + CAN SLIM hybrid for Indian equity markets. Regime-adaptive swing trading with volatility contraction entries, ATR-based risk management, and multi-target exits.",
    "version": "5.1",
    "analysis_config": {
        "technical_analysis": true,
        "fundamental_analysis": false,
        "sentiment_analysis": false,
        "sector_analysis": false,
        "market_regime_detection": true,
        "backtesting": true,
        "individual_stock_backtest": false,
        "risk_management": true,
        "options_oi": false
    },
    "analysis_weights": {
        "technical": 1.0,
        "fundamental": 0.0,
        "sentiment": 0.0,
        "sector": 0.0
    },
    "rs_config": {
        "benchmark_index": "^NSEI",
        "period": 55,
        "threshold": 1.0
    },
    "market_regime_config": {
        "index": "^NSEI",
        "bull_market_rule": "latest close > sma(200)",
        "pause_buying_if_bearish": true,
        "adaptive_mode": true,
        "adx_min": 20,
        "require_adx": true
    },
    "stock_filters": [
        {
            "type": "price",
            "op": ">",
            "value": 50.0
        },
        {
            "type": "volume",
            "op": ">",
            "value": 100000
        },
        {
            "type": "market_cap",
            "op": ">",
            "value": 500.0
        },
        {
            "type": "moving_average",
            "kind": "SMA",
            "period": 50,
            "op": ">",
            "target": "close"
        },
        {
            "type": "moving_average",
            "kind": "SMA",
            "period": 200,
            "op": ">",
            "target": "close"
        }
    ],
    "recommendation_thresholds": {
        "buy_combined": 0.50,
        "technical_minimum": 0.30,
        "fundamental_minimum": 0.0,
        "require_all_gates": false,
        "min_risk_reward_ratio": 1.2,
        "min_backtest_return": 0.0,
        "backtest_period": "2y",
        "min_data_required_days": 252,
        "proximity_to_52_week_high_pct": 30.0
    },
    "indicator_periods": {
        "adx": 14,
        "rsi": 14,
        "atr": 14,
        "bb": 20,
        "macd_fast": 12,
        "macd_slow": 26,
        "macd_signal": 9
    },
    "strategy_config": {
        "RSI_Overbought_Oversold": {
            "enabled": true,
            "is_bonus": true,
            "overbought": 70,
            "oversold": 30
        },
        "MACD_Signal_Crossover": {
            "enabled": true,
            "is_bonus": true
        },
        "ADX_Trend_Strength": {
            "enabled": true,
            "is_bonus": false,
            "period": 14,
            "threshold": 18
        },
        "On_Balance_Volume": {
            "enabled": true,
            "is_bonus": true,
            "lookback_period": 20
        },
        "Bollinger_Band_Squeeze": {
            "enabled": true,
            "is_bonus": true,
            "period": 20,
            "std": 2.0,
            "squeeze_threshold": 0.10
        },
        "Relative_Strength_Comparison": {
            "enabled": true,
            "is_bonus": false,
            "period": 90,
            "threshold": 1.0
        },
        "Pocket_Pivot_Entry": {
            "enabled": false,
            "is_bonus": true
        },
        "Volume_Breakout": {
            "enabled": true,
            "is_bonus": false,
            "volume_multiplier": 1.3,
            "lookback": 20
        },
        "Candlestick_Patterns": {
            "enabled": true,
            "is_bonus": true,
            "patterns": {
                "bullish_engulfing": true,
                "hammer": true,
                "morning_star": true
            }
        }
    },
    "swing_trading_gates": {
        "TREND_GATE": {
            "enabled": true,
            "params": {
                "adx_min": 18,
                "adx_max": 80,
                "sma_period": 50,
                "require_price_above_sma": true,
                "require_sma_stack": false,
                "require_di_plus_above_di_minus": true,
                "min_di_diff": 3
            }
        },
        "VOLATILITY_GATE": {
            "enabled": true,
            "params": {
                "min_percentile": 10,
                "max_percentile": 70,
                "lookback_days": 100
            }
        },
        "VOLUME_GATE": {
            "enabled": true,
            "params": {
                "min_volume_ratio": 1.0,
                "obv_trend_lookback": 10,
                "logic_operator": "AND"
            }
        }
    },
    "entry_patterns": [
        {
            "name": "volatility_contraction",
            "enabled": true,
            "min_contractions": 2,
            "max_contractions": 5,
            "volume_dry_up_required": false,
            "max_atr_pct_of_price": 5.0,
            "require_vcp_shape": false,
            "max_contraction_depth_pct": 30.0,
            "min_contraction_duration_days": 3,
            "max_contraction_duration_days": 90,
            "atr_decrease_days": 3
        },
        {
            "name": "pullback_to_ema",
            "enabled": true,
            "ema_period": 21,
            "rsi_range": [35, 65],
            "max_distance_from_ema_pct": 2.0
        },
        {
            "name": "bollinger_squeeze_breakout",
            "enabled": true,
            "bb_period": 20,
            "bb_std": 2.0,
            "squeeze_threshold": 0.10,
            "require_volume_confirm": true,
            "min_volume_multiplier": 1.3
        },
        {
            "name": "twenty_day_high_breakout",
            "enabled": true,
            "volume_confirm": true,
            "min_volume_multiplier": 1.3
        },
        {
            "name": "nr7_volatility_squeeze",
            "enabled": true,
            "lookback": 7,
            "volume_dry_up": false
        }
    ],
    "exit_rules": {
        "targets": [
            {
                "name": "Target 1",
                "atr_multiplier": 2.0,
                "sell_percentage": 0.5
            },
            {
                "name": "Target 2",
                "atr_multiplier": 3.5,
                "sell_percentage": 1.0
            }
        ],
        "atr_stop_multiplier": 1.5,
        "trail_stop_type": "atr",
        "trail_stop_atr_multiplier": 2.0,
        "trail_stop_ma_period": 20,
        "time_stop_bars": 40,
        "breakeven_at_target_1": true,
        "max_daily_loss_pct": 3.0,
        "leader_exception": {
            "enabled": true,
            "min_gain_pct": 20.0,
            "max_weeks": 8,
            "action": "hold_and_trail"
        },
        "regime_adaptive_exits": {
            "bull": {
                "t1_sell_percentage": 0.5,
                "atr_stop_multiplier": 1.5,
                "trail_stop_type": "atr",
                "trail_stop_atr_multiplier": 2.0,
                "pyramiding_allowed": true
            },
            "bear": {
                "t1_sell_percentage": 1.0,
                "atr_stop_multiplier": 1.0,
                "trail_stop_type": "atr",
                "trail_stop_atr_multiplier": 1.5,
                "pyramiding_allowed": false
            }
        }
    },
    "risk_management": {
        "risk_per_trade_pct": 1.5,
        "max_risk_per_trade_pct": 2.0,
        "max_position_pct": 15.0,
        "max_positions": 8,
        "stop_loss_type": "ATR",
        "position_sizing": "risk_based",
        "volatility_scaling": {
            "enabled": true,
            "atr_lookback_days": 100,
            "low_volatility_percentile": 25,
            "high_volatility_percentile": 75,
            "min_risk_multiplier": 0.5
        },
        "regime_adaptive_risk": {
            "bull": {
                "risk_per_trade_pct": 1.5,
                "max_positions": 8
            },
            "bear": {
                "risk_per_trade_pct": 0.5,
                "max_positions": 2
            }
        }
    },
    "pyramiding": {
        "enabled": true,
        "max_steps": 2,
        "steps": [
            {
                "name": "First Add",
                "trigger_profit_pct": 8.0,
                "trigger_step_atr": 1.5,
                "add_size_pct": 0.5
            },
            {
                "name": "Second Add",
                "trigger_profit_pct": 15.0,
                "trigger_step_atr": 3.0,
                "add_size_pct": 0.3
            }
        ],
        "regime_controlled": true
    },
    "volume_analysis_config": {
        "volume_breakout_multiplier": 1.5,
        "volume_strong_multiplier": 2.0,
        "volume_weak_threshold": 0.5,
        "volume_lookback": 20,
        "trend_lookback": 10,
        "divergence_lookback": 10
    },
    "chartink_config": {
        "enabled": true,
        "cache_ttl_minutes": 60
    },
    "rsi_momentum_filter": {
        "enabled": true,
        "min_rsi": 45,
        "require_rising": false
    }
}
