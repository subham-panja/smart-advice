{
    "name": "Delayed_EP",
    "enabled": true,
    "analysis_config": {
        "technical_analysis": true,
        "fundamental_analysis": true,
        "sentiment_analysis": false,
        "sector_analysis": true,
        "market_regime_detection": false,
        "backtesting": true,
        "risk_management": true
    },
    "analysis_weights": {
        "technical": 0.90,
        "fundamental": 0.05,
        "sentiment": 0.00,
        "sector": 0.05
    },
    "stock_filters": [
        { "type": "price", "op": "between", "min": 20, "max": 50000 },
        { "type": "volume", "op": ">", "value": 100000 },
        { "type": "market_cap", "op": ">", "value": 2000 },
        { "type": "moving_average", "kind": "SMA", "period": 50, "op": "<", "target": "close" },
        { "type": "moving_average", "kind": "SMA", "period": 200, "op": "<", "target": "close" },
        { "type": "moving_average", "kind": "SMA", "period": 10, "op": "<", "target": "close" },
        { "type": "rsi", "period": 14, "op": ">", "value": 50 },
        { 
            "type": "volume_spike_lookup", 
            "lookback_days": 5, 
            "multiplier": 3.0, 
            "ma_period": 50 
        }
    ],
    "strategy_config": {
        "RSI_Overbought_Oversold": {"enabled": false, "period": 14, "upper": 70, "lower": 30},
        "MACD_Signal_Crossover": {"enabled": true, "fast": 12, "slow": 26, "signal": 9},
        "ADX_Trend_Strength": {"enabled": true, "period": 14, "threshold": 15},
        "On_Balance_Volume": {"enabled": true, "lookback": 20},
        "Bollinger_Band_Squeeze": {"enabled": true, "period": 20, "std": 2, "volatility_limit": 2.5},
        "Relative_Strength_Comparison": {"enabled": true, "period": 55, "threshold": 0.0},
        "Pocket_Pivot_Entry": {"enabled": true, "max_down_days": 10},
        "Volume_Breakout": {"enabled": true, "period": 20, "threshold": 2.5}
    },
    "recommendation_thresholds": {
        "buy_combined": 0.30,
        "technical_minimum": 0.28,
        "fundamental_minimum": -0.50,
        "require_all_gates": true,
        "min_risk_reward_ratio": 2
    },
    "swing_trading_gates": {
        "TREND_GATE": {
            "enabled": true,
            "params": {
                "adx_min": 15,
                "adx_max": 50,
                "macd_zero_buffer": 0.1,
                "sma_period": 50,
                "require_price_above_sma": false,
                "require_sma_stack": false,
                "adx_slope_check": true
            }
        },
        "VOLATILITY_GATE": {
            "enabled": false,
            "params": {
                "min_percentile": 20,
                "max_percentile": 80,
                "lookback_days": 100
            }
        },
        "VOLUME_GATE": {
            "enabled": true,
            "params": {
                "zscore_threshold": 0.2,
                "obv_trend_lookback": 10,
                "logic_operator": "OR"
            }
        },
        "MTF_GATE": {
            "enabled": true,
            "params": {
                "weekly_trend_check": false,
                "weekly_sma_fast": 10,
                "weekly_sma_slow": 30,
                "rsi_alignment_min": 60
            }
        }
    },
    "entry_patterns": [
        {
            "name": "pullback_to_ema",
            "enabled": true,
            "ema_period": 10,
            "rsi_range": [40, 70],
            "bullish_candle_required": true
        },
        {
            "name": "bollinger_squeeze_breakout",
            "enabled": true,
            "bb_period": 20,
            "bb_std": 2,
            "squeeze_threshold": 0.05,
            "retest_required": true,
            "max_squeeze_duration_days": 20
        },
        {"name": "macd_zero_cross", "enabled": true, "fast": 12, "slow": 26, "signal": 9, "above_zero_only": true},
        {"name": "higher_low_structure", "enabled": true, "pivot_lookback": 5, "min_swings": 2},
        {"name": "volatility_contraction", "enabled": true, "min_contractions": 2, "volume_dry_up_required": true}
    ],
    "exit_rules": {
        "targets": [
            {"name": "Target 1", "atr_multiplier": 3.0, "sell_percentage": 0.5},
            {"name": "Target 2", "atr_multiplier": 4.5, "sell_percentage": 1.0}
        ],
        "atr_stop_multiplier": 1.5,
        "trail_stop_atr": 3.0,
        "time_stop_bars": 15,
        "breakeven_at_target_1": true
    },
    "chartink_config": {
        "cache_ttl_minutes": 60
    },
    "rs_config": {
        "benchmark_index": "^NSEI",
        "period": 55,
        "threshold": 0.0
    },
    "market_regime_config": {
        "index": "^NSEI",
        "bull_market_rule": "latest close > sma(50)",
        "pause_buying_if_bearish": true
    },
    "options_oi_config": {
        "enabled": true,
        "weight": 0.15,
        "min_unwinding_pct": 5.0,
        "pcr_bullish_threshold": 1.2,
        "pcr_bearish_threshold": 0.7,
        "expiry_type": "CURRENT"
    },
    "risk_management": {
        "position_sizing": {
            "risk_per_trade": 0.01,
            "max_position_pct": 0.10
        },
        "pyramiding": {
            "enabled": true,
            "max_adds": 2,
            "steps": [
                {"name": "Add 1", "trigger_step_atr": 1.5, "add_size_pct": 0.5},
                {"name": "Add 2", "trigger_step_atr": 1.5, "add_size_pct": 0.25}
            ]
        }
    }
}
