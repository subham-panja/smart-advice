{
    "name": "Momentum_Trading",
    "enabled": true,
    "description": "Momentum strategy focusing on 52-week high breakouts, relative strength leaders, and trending stocks. Wider stops, longer holds, and concentrated positions for capturing multi-month moves.",
    "version": "1.0",
    "analysis_config": {
        "technical_analysis": true,
        "fundamental_analysis": true,
        "sentiment_analysis": false,
        "sector_analysis": true,
        "market_regime_detection": true,
        "backtesting": true,
        "risk_management": true,
        "options_oi": true
    },
    "analysis_weights": {
        "technical": 0.70,
        "fundamental": 0.15,
        "sentiment": 0.00,
        "sector": 0.15
    },
    "rs_config": {
        "benchmark_index": "^NSEI",
        "period": 55,
        "threshold": 1.0
    },
    "market_regime_config": {
        "index": "^NSEI",
        "bull_market_rule": "latest close > sma(50)",
        "pause_buying_if_bearish": true
    },
    "options_oi_config": {
        "enabled": true,
        "weight": 0.10,
        "min_unwinding_pct": 5.0,
        "pcr_bullish_threshold": 1.0,
        "pcr_bearish_threshold": 1.3,
        "expiry_type": "CURRENT"
    },
    "stock_filters": [
        {
            "type": "price",
            "op": "between",
            "min": 50.0,
            "max": 8000.0
        },
        {
            "type": "volume",
            "op": ">",
            "value": 150000
        },
        {
            "type": "market_cap",
            "op": ">",
            "value": 1000.0
        },
        {
            "type": "moving_average",
            "kind": "SMA",
            "period": 50,
            "op": ">",
            "target": "close"
        },
        {
            "type": "moving_average",
            "kind": "SMA",
            "period": 150,
            "op": ">",
            "target": "close"
        },
        {
            "type": "moving_average",
            "kind": "SMA",
            "period": 200,
            "op": ">",
            "target": "close"
        },
        {
            "type": "volume_spike_lookup",
            "lookback_days": 10,
            "multiplier": 1.2,
            "ma_period": 50
        }
    ],
    "recommendation_thresholds": {
        "buy_combined": 0.50,
        "technical_minimum": 0.40,
        "fundamental_minimum": 0.10,
        "require_all_gates": true,
        "min_risk_reward_ratio": 2.0,
        "min_backtest_return": 0.0,
        "backtest_period": "5y",
        "min_data_required_days": 252,
        "proximity_to_52_week_high_pct": 40.0
    },
    "strategy_config": {
        "RSI_Overbought_Oversold": {
            "enabled": false,
            "is_bonus": true,
            "rsi_period": 14,
            "overbought_level": 70,
            "oversold_level": 30
        },
        "MACD_Signal_Crossover": {
            "enabled": false,
            "is_bonus": false,
            "fast_period": 12,
            "slow_period": 26,
            "signal_period": 9
        },
        "ADX_Trend_Strength": {
            "enabled": true,
            "is_bonus": false,
            "period": 14,
            "threshold": 20
        },
        "On_Balance_Volume": {
            "enabled": true,
            "is_bonus": true,
            "lookback_period": 20
        },
        "Bollinger_Band_Squeeze": {
            "enabled": false,
            "is_bonus": false,
            "period": 20,
            "std": 2,
            "volatility_limit": 2.5,
            "atr_multiplier": 1.5,
            "squeeze_threshold": 0.95
        },
        "Relative_Strength_Comparison": {
            "enabled": true,
            "is_bonus": false,
            "period": 55,
            "threshold": 0.0
        },
        "Pocket_Pivot_Entry": {
            "enabled": false,
            "is_bonus": true,
            "lookback": 10,
            "sma_fast": 10,
            "sma_slow": 50
        },
        "Volume_Breakout": {
            "enabled": true,
            "is_bonus": false,
            "period": 20,
            "threshold": 2.0
        },
        "Candlestick_Patterns": {
            "enabled": false,
            "is_bonus": true,
            "patterns": {
                "bullish_engulfing": true,
                "hammer": true,
                "morning_star": true
            }
        }
    },
    "swing_trading_gates": {
        "TREND_GATE": {
            "enabled": true,
            "params": {
                "adx_min": 12,
                "adx_max": 50,
                "macd_zero_buffer": 0.1,
                "sma_period": 50,
                "require_price_above_sma": true,
                "require_sma_stack": false,
                "adx_slope_check": true,
                "require_di_plus_above_di_minus": true,
                "min_di_diff": 5
            }
        },
        "VOLATILITY_GATE": {
            "enabled": true,
            "params": {
                "min_percentile": 5,
                "max_percentile": 95,
                "lookback_days": 100
            }
        },
        "VOLUME_GATE": {
            "enabled": true,
            "params": {
                "zscore_threshold": 0.0,
                "obv_trend_lookback": 10,
                "logic_operator": "OR",
                "require_volume_above_ma": true
            }
        },
        "MTF_GATE": {
            "enabled": true,
            "params": {
                "weekly_trend_check": true,
                "weekly_sma_fast": 10,
                "weekly_sma_slow": 30,
                "rsi_alignment_min": 55
            }
        }
    },
    "entry_patterns": [
        {
            "name": "pullback_to_ema",
            "enabled": true,
            "ema_period": 21,
            "rsi_range": [35, 65],
            "bullish_candle_required": true,
            "max_distance_pct": 2.0
        },
        {
            "name": "bollinger_squeeze_breakout",
            "enabled": true,
            "bb_period": 20,
            "bb_std": 2,
            "squeeze_threshold": 0.10,
            "retest_required": false,
            "max_squeeze_duration_days": 20
        },
        {
            "name": "macd_zero_cross",
            "enabled": false,
            "fast": 12,
            "slow": 26,
            "signal": 9,
            "above_zero_only": true,
            "require_histogram_expansion": true
        },
        {
            "name": "higher_low_structure",
            "enabled": false,
            "pivot_lookback": 7,
            "min_swings": 3,
            "require_volume_confirmation": true
        },
        {
            "name": "volatility_contraction",
            "enabled": true,
            "min_contractions": 3,
            "volume_dry_up_required": true,
            "max_atr_pct_of_price": 3.0
        },
        {
            "name": "twenty_day_high_breakout",
            "enabled": true,
            "volume_confirm": true,
            "min_volume_multiplier": 1.5
        },
        {
            "name": "nr7_volatility_squeeze",
            "enabled": true,
            "lookback": 7,
            "volume_dry_up": true
        }
    ],
    "exit_rules": {
        "targets": [
            {
                "name": "Target 1",
                "atr_multiplier": 5.0,
                "sell_percentage": 0.5
            },
            {
                "name": "Target 2",
                "atr_multiplier": 10.0,
                "sell_percentage": 1.0
            }
        ],
        "atr_stop_multiplier": 2.5,
        "trail_stop_atr": 3.5,
        "time_stop_bars": 40,
        "breakeven_at_target_1": false,
        "max_daily_loss_pct": 2.0
    },
    "risk_management": {
        "risk_per_trade_pct": 2.0,
        "max_position_pct": 20.0,
        "max_positions": 8,
        "stop_loss_type": "ATR",
        "position_sizing": "risk_based"
    },
    "pyramiding": {
        "enabled": true,
        "max_steps": 2,
        "steps": [
            {
                "name": "First Add",
                "trigger_step_atr": 2.0,
                "add_size_pct": 0.5
            },
            {
                "name": "Second Add",
                "trigger_step_atr": 4.0,
                "add_size_pct": 0.3
            }
        ]
    },
    "fundamental_config": {
        "min_roce": 18.0,
        "max_debt_to_equity": 1.0,
        "min_profit_growth_3y": 10.0,
        "min_profit_growth_5y": 10.0,
        "min_quarterly_eps_growth": 0.20
    },
    "volume_analysis_config": {
        "breakout_multiplier": 2.0,
        "accumulation_lookback": 10,
        "trend_ma_period": 20
    },
    "chartink_config": {
        "enabled": true,
        "cache_ttl_minutes": 60
    }
}
