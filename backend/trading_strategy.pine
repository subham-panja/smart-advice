//@version=5
strategy("Smart Advice Swing Strategy", overlay=true, initial_capital=100000, default_qty_type=strategy.percent_of_equity, default_qty_value=20, commission_type=strategy.commission.percent, commission_value=0.1)

// ==============================================================================
// 1. MACRO / FUNDAMENTAL FILTERS (From Chartink)
// ==============================================================================
minPrice = 20.0
maxPrice = 50000.0
priceFilter = close > minPrice and close < maxPrice

// ==============================================================================
// 2. TREND & CHARTINK SETUP FILTERS
// ==============================================================================
sma50 = ta.sma(close, 50)
sma200 = ta.sma(close, 200)

// Price above moving averages
trendFilter = (close > sma50) and (close > sma200)

// Volume Surge: Today's volume > 2x the 20-day average volume
volSma20 = ta.sma(volume, 20)
volSurge = volume > (volSma20 * 2)

// Breakout structure: Close > highest high of the previous 20 days
highest20 = ta.highest(high[1], 20) // [1] means excluding today's high
breakout20 = close > highest20

// Near High: Close is within 2% of the all-time/recent high
// Note: TradingView looks at the chart's visible data. We'll use a 250-day (1 year) lookback for "High"
highest250 = ta.highest(high, 250)
nearHigh = close >= (highest250 * 0.98)

// Green Candle
greenCandle = close > open

// ==============================================================================
// 3. TECHNICAL ALGO CONFIRMATION (From Python Analyzer)
// ==============================================================================
// RSI > 60
rsi14 = ta.rsi(close, 14)
rsiBullish = rsi14 > 60

// MACD positive
[macdLine, signalLine, _] = ta.macd(close, 12, 26, 9)
macdBullish = macdLine > signalLine and macdLine > 0

// ADX > 20 (Strong Trend)
[diPlus, diMinus, adx14] = ta.dmi(14, 14)
adxBullish = adx14 > 20 and diPlus > diMinus

// ==============================================================================
// 4. COMBINED SIGNAL (The "Gates")
// ==============================================================================
// To enter a trade, ALL these conditions must be met simultaneously
buySignal = priceFilter and trendFilter and volSurge and breakout20 and nearHigh and greenCandle and rsiBullish and macdBullish and adxBullish

// Plot entry signals on chart
plotshape(buySignal, title="Buy Signal", location=location.belowbar, color=color.green, style=shape.triangleup, size=size.normal)

// ==============================================================================
// 5. TRADE MANAGEMENT (Risk Management / Stop Loss)
// ==============================================================================
// ATR-based Stop Loss (2 * 14-day ATR)
atr14 = ta.atr(14)
atrMultiplier = 2.0

var float stopLossPrice = na
var float takeProfitPrice = na

if (buySignal and strategy.position_size == 0)
    // Execute Buy
    strategy.entry("Long", strategy.long)
    
    // Calculate Stop Loss and Take Profit at entry
    stopLossPrice := close - (atr14 * atrMultiplier)
    
    // Calculate a 1:2.5 Risk to Reward ratio for Take Profit
    riskPerShare = close - stopLossPrice
    takeProfitPrice := close + (riskPerShare * 2.5)

// Manage open positions
if (strategy.position_size > 0)
    // Exit if price hits stop loss or take profit
    strategy.exit("Exit Long", from_entry="Long", stop=stopLossPrice, limit=takeProfitPrice)
    
    // Optional: Trailing Stop Loss (move SL up if price moves in our favor)
    // Uncomment the lines below to enable trailing stop
    // newStop = close - (atr14 * atrMultiplier)
    // if (newStop > stopLossPrice)
    //     stopLossPrice := newStop

// Plot Stop Loss line for visual reference
plot(strategy.position_size > 0 ? stopLossPrice : na, color=color.red, style=plot.style_linebr, linewidth=2, title="Stop Loss")
plot(strategy.position_size > 0 ? takeProfitPrice : na, color=color.green, style=plot.style_linebr, linewidth=2, title="Take Profit")
